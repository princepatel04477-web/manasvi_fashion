generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Order {
  id        String   @id @default(cuid())
  orderNo   String   @unique
  amount    Int
  status    String
  createdAt DateTime @default(now())
}
